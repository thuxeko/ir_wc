# ============================================
# WC26 Predict - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# .env.example is committed to git as a template.
# .env (real secrets) is ignored by git.

# --------------------------------------------
# Required: JWT secret for signing session tokens
# --------------------------------------------
# Generate a strong random string, e.g.:
#   openssl rand -base64 32
# In production, this MUST be set and kept secret.
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# --------------------------------------------
# Optional: Auto-create admin user on first run
# --------------------------------------------
# If set, the app will create an active admin user on startup
# (only if the user does not already exist). Admin should change
# the password after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-admin-123

# --------------------------------------------
# Optional: Node environment
# --------------------------------------------
# development | production
# In production, cookies are sent only over HTTPS.
NODE_ENV=production

# --------------------------------------------
# Optional: Server port
# --------------------------------------------
# Default: 3000
PORT=3000

# --------------------------------------------
# Docker deployment notes
# --------------------------------------------
# For Docker, mount a persistent volume for the SQLite database
# so data is not lost when the container restarts:
#
#   docker run -d \
#     -p 3000:3000 \
#     -v wc2026-data:/app/data \
#     -e JWT_SECRET=your-secret \
#     wc2026-predict
#
# Database file: /app/data/wc2026.db
# Backups folder: /app/data/backups/
